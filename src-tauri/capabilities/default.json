{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the menu bar popover window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:tray:default",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-position",
    "core:window:allow-set-focus",
    "core:window:allow-is-visible",
    "opener:default",
    "allow-set-tray-icon"
  ]
}
