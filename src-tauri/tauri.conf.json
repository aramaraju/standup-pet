{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Standup Pet",
  "version": "0.1.0",
  "identifier": "com.aravind.standup-pet",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Standup Pet",
        "width": 380,
        "height": 580,
        "minWidth": 380,
        "maxWidth": 380,
        "minHeight": 520,
        "maxHeight": 700,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "shadow": true,
        "url": "index.html?view=main"
      },
      {
        "label": "focus_hud",
        "title": "Focus",
        "width": 220,
        "height": 72,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "visible": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "shadow": false,
        "url": "index.html?view=focus_hud"
      },
      {
        "label": "flash_overlay",
        "title": "Flash",
        "width": 1920,
        "height": 1200,
        "x": 0,
        "y": 0,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "shadow": false,
        "url": "index.html?view=flash_overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    },
    "resources": {
      "icons/tray/": "icons/tray/"
    }
  }
}
